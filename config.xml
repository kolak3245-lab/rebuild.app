<?xml version="1.0" encoding="UTF-8"?>
<widget id="com.aplkont.app" version="1.0.0" android-versionCode="1"
  xmlns="http://www.w3.org/ns/widgets"
  xmlns:cdv="http://cordova.apache.org/ns/1.0">

  <name>Aplikasi pro</name>
  <description>Built with APK Builder</description>
  <author>APK Builder</author>

  <content src="index.html" />
  <access origin="*" />
  <allow-intent href="http://*/*" />
  <allow-intent href="https://*/*" />

  <preference name="DisallowOverscroll" value="true" />
  <preference name="Orientation" value="default" />
  <preference name="Fullscreen" value="false" />

  <!-- Hanya plugin inti yang pasti kompatibel -->
  <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
  <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />
  <plugin name="cordova-plugin-device" spec="^3.0.0" />

  <platform name="android">
    <allow-intent href="market:*" />
    <preference name="android-minSdkVersion" value="23" />
    <preference name="android-targetSdkVersion" value="34" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
  </platform>

</widget>